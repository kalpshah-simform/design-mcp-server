    "tags": ["actions", "forms", "deprecated"],
    "aliases": [],
    "interactive": true,
    "deprecated": true,
    "deprecatedVersion": "2.0.0",
    "replacement": "Button",
    "migrationNotes": "ButtonLegacy was renamed to Button in v2.0.0. Update all imports from ButtonLegacy to Button and use the new 'variant' prop instead of 'type' prop.",
    "docsUrl": "https://design.example.com/components/button-legacy",
    "storybookUrl": "https://storybook.example.com/?path=/docs/components-buttonlegacy--docs"
  }
}
